// Generated by Claude (claude-opus-4-7) on 2026-05-22.
// 全方位木DP / Rerooting
//
// 木 g 上で、各頂点 v について「v を根としたときの木全体の集約値」を O(N) で求める。
//
// 使い方: 以下の3つを定義する。
//   - op(a, b)       : 子方向の部分木結果 S 同士をマージ（モノイド、単位元 e）
//   - put_edge(a, e) : 子の頂点結果 S に「子→親の辺 e」の寄与を載せる
//   - put_vertex(a,v): 子方向からの集約 a を、頂点 v の寄与で閉じる
//
// dp[v][i] = 頂点 v の i 番目の隣接 g[v][i] 方向の部分木結果（put_edge 適用後、put_vertex 未適用）
// ans[v]   = v を根としたときの全体結果 = put_vertex(op(...全dp[v][i]...), v)
//
// 例(部分木サイズの総和=∑d(v,u)): S=pair<lli,lli>{sum_dist, size},
//   e={0,0}, op(a,b)={a.f+b.f, a.s+b.s},
//   put_edge(a, w)={a.f + a.s*w, a.s},  // 辺重み w を加算（辺なら w=1）
//   put_vertex(a, v)={a.f, a.s + 1}.
//
// 参考: https://ei1333.hateblo.jp/entry/2017/04/10/224413
//       https://trap.jp/post/1702/
template<typename S, typename E>
struct Rerooting {
  using F_op   = function<S(S, S)>;
  using F_pe   = function<S(S, const E&)>;
  using F_pv   = function<S(S, int)>;
  const S e;
  const F_op op;
  const F_pe put_edge;
  const F_pv put_vertex;
  const int n;
  vector<vector<pair<int, E>>> g; // g[u] = { (v, edge u->v) }
  vector<vector<S>> dp;
  vector<S> ans;
  Rerooting(int n_, S e_, F_op op_, F_pe pe_, F_pv pv_)
    : e(e_), op(op_), put_edge(pe_), put_vertex(pv_), n(n_), g(n_) {}
  // 無向辺。方向ごとに辺情報が異なる場合は (u,v,euv,evu) を使う
  void add_edge(int u, int v, const E& euv, const E& evu) {
    g[u].emplace_back(v, euv);
    g[v].emplace_back(u, evu);
  }
  void add_edge(int u, int v, const E& w) { add_edge(u, v, w, w); }

  S dfs1(int u, int p) {
    S res = e;
    dp[u].assign(g[u].size(), e);
    for (size_t i = 0; i < g[u].size(); ++i) {
      auto& [v, ed] = g[u][i];
      if (v == p) continue;
      dp[u][i] = put_edge(dfs1(v, u), ed);
      res = op(res, dp[u][i]);
    }
    return put_vertex(res, u);
  }

  void dfs2(int u, int p, S from_parent) {
    const int k = g[u].size();
    for (int i = 0; i < k; ++i) {
      if (g[u][i].first == p) { dp[u][i] = from_parent; break; }
    }
    vector<S> L(k + 1, e), R(k + 1, e);
    for (int i = 0; i < k; ++i)       L[i + 1] = op(L[i], dp[u][i]);
    for (int i = k - 1; i >= 0; --i)  R[i]     = op(R[i + 1], dp[u][i]);
    ans[u] = put_vertex(L[k], u);
    for (int i = 0; i < k; ++i) {
      auto& [v, ed] = g[u][i];
      if (v == p) continue;
      S rest = put_vertex(op(L[i], R[i + 1]), u);
      dfs2(v, u, put_edge(rest, ed));
    }
  }

  // root はどこでもよい（結果は root に依存しない）。
  void build(int root = 0) {
    assert(0 <= root && root < n);
    dp.assign(n, {});
    ans.assign(n, e);
    dfs1(root, -1);
    dfs2(root, -1, e);
  }
};
